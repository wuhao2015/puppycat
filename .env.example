# ---------------------------------------------------------------------------
# Puppycat Travel App — environment configuration
# Copy to `.env` and fill in real values. Never commit `.env`.
# ---------------------------------------------------------------------------

# --- Database ---
# When using docker-compose, host is `db`. For local runs use `localhost`.
POSTGRES_USER=puppycat
POSTGRES_PASSWORD=puppycat
POSTGRES_DB=puppycat
DATABASE_URL=postgresql+asyncpg://puppycat:puppycat@db:5432/puppycat

# --- LLM provider ---
# "gemini" (default, free on Google AI Studio) or "openai".
LLM_PROVIDER=gemini

# Gemini — get a free API key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Free Flash models (1,500 req/day). Pro models are paid-only or 50 RPD since April 2026.
#
# Recommended free options (pick any Flash model for either tier):
#   gemini-2.5-flash       — solid quality, thinking mode, definitely free ✓
#   gemini-3-flash         — newer, also free ✓
#   gemini-3.5-flash       — newest Flash, also free ✓
#   gemini-3.1-flash-lite  — fastest/cheapest, also free ✓
#
# DO NOT use gemini-2.5-pro or gemini-3.1-pro-preview for free use (paid-only / 50 RPD).
LLM_CHEAP_MODEL=gemini-2.5-flash
LLM_SYNTHESIS_MODEL=gemini-2.5-flash

# OpenAI — leave blank if using Gemini.
OPENAI_API_KEY=
# Optional base URL override (e.g. for Azure/OpenAI-compatible gateways).
OPENAI_BASE_URL=

# --- Google Places API (New) ---
GOOGLE_PLACES_API_KEY=your-google-places-key

# --- Web search (freshness layer) ---
# Provider: "tavily" (default) or "brave".
WEB_SEARCH_PROVIDER=tavily
TAVILY_API_KEY=tvly-your-key
BRAVE_SEARCH_API_KEY=

# --- Cost controls ---
# Hard daily cap on estimated LLM spend (USD). Requests are refused past this.
DAILY_LLM_BUDGET_USD=2.0

# --- Cache TTLs (seconds) ---
CACHE_TTL_PLACES=21600        # 6h for POI details / hours
CACHE_TTL_WEB_SEARCH=3600     # 1h for freshness searches
CACHE_TTL_WEATHER=10800       # 3h for weather

# --- App ---
# Single-user API key for v1. Swap for real auth when going multi-user.
APP_API_KEY=dev-local-key
CORS_ALLOW_ORIGINS=http://localhost:3000

# --- Frontend ---
# The API is published on host port 8001 (8001->8000) to avoid clashing with
# other local services. The browser must reach it here.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8001
NEXT_PUBLIC_MAPBOX_TOKEN=pk.your-mapbox-token
# Must match APP_API_KEY above; sent as the X-API-Key header from the browser.
NEXT_PUBLIC_API_KEY=dev-local-key
